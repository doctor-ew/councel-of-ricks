# Database
DATABASE_URL=postgresql+asyncpg://depo:localdev@localhost:5432/deposition_prep

# Anthropic (LLM calls)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (embeddings only — Claude has no embedding API)
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Application
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# Document Storage
DOCUMENTS_PATH=./transcripts

# Optional: OCR (install tesseract via: brew install tesseract)
# TESSERACT_PATH=/opt/homebrew/bin/tesseract
